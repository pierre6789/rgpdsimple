<section class="hero">
  <div class="container hero-grid">
    <div class="hero-main">
      <p class="hero-badge">Conforme RGPD 2026 • Spécial TPE & artisans</p>
      <h1>Vos documents RGPD prêts en <span class="highlight">5 minutes</span></h1>
      <p class="hero-subtitle">
        Générateur automatique de documents légaux pour restaurants, artisans, garages, consultants, e‑commerçants…
        Vous répondez à quelques questions, nous créons vos documents conformes CNIL.
      </p>
      <ul class="hero-benefits">
        <li>Politique de confidentialité personnalisée</li>
        <li>Mentions légales + CGV adaptées à votre activité</li>
        <li>Registre des traitements CNIL + bandeau cookies prêt à intégrer</li>
      </ul>
      <div class="hero-actions">
        <a href="#form" class="btn-cta">
          Obtenir mes documents RGPD - {{price}} €
        </a>
        <p class="hero-small-text">Paiement sécurisé par Stripe • Envoi immédiat par email</p>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-dot"></span> Pensé pour les non-juristes
        </div>
        <div class="trust-item">
          <span class="trust-dot"></span> Aucun abonnement, paiement unique
        </div>
        <div class="trust-item">
          <span class="trust-dot"></span> Modèles facilement modifiables
        </div>
      </div>
    </div>
    <aside class="hero-card" id="form">
      <h2 class="card-title">Démarrer votre pack RGPD</h2>
      <p class="card-subtitle">2 minutes pour sécuriser votre activité.</p>
      <form method="POST" action="/checkout" class="rgpd-form">
        <div class="form-row">
          <div class="form-group">
            <label for="companyName">Nom de l'entreprise</label>
            <input type="text" id="companyName" name="companyName" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="businessType">Type d'activité</label>
            <select id="businessType" name="businessType" required>
              <option value="">Sélectionnez…</option>
              <option value="restaurant">Restaurant</option>
              <option value="coiffeur">Coiffeur</option>
              <option value="garage">Garage</option>
              <option value="commerce">Commerce</option>
              <option value="artisan_btp">Artisan BTP</option>
              <option value="consultant">Consultant</option>
              <option value="ecommerce">E-commerce</option>
              <option value="impression_3d">Impression 3D</option>
              <option value="autre">Autre</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="address">Adresse complète</label>
            <textarea id="address" name="address" rows="3" required></textarea>
          </div>
        </div>

        <div class="form-row two-cols">
          <div class="form-group">
            <label for="email">Email de réception</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="website">Site web (optionnel)</label>
            <input type="url" id="website" name="website" placeholder="https://…" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Collectez-vous des emails clients ?</label>
            <div class="pill-toggle">
              <label class="pill-option">
                <input type="radio" name="collectsEmails" value="yes" required />
                <span>Oui</span>
              </label>
              <label class="pill-option">
                <input type="radio" name="collectsEmails" value="no" />
                <span>Non</span>
              </label>
            </div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Avez-vous un site web avec cookies ?</label>
            <div class="pill-toggle">
              <label class="pill-option">
                <input type="radio" name="hasCookies" value="yes" required />
                <span>Oui</span>
              </label>
              <label class="pill-option">
                <input type="radio" name="hasCookies" value="no" />
                <span>Non</span>
              </label>
            </div>
          </div>
        </div>

        <button type="submit" class="btn-cta btn-full">
          Payer {{price}} € et générer mes documents
        </button>
        <p class="form-note">Paiement sécurisé par Stripe. Envoi automatique des 5 PDFs par email.</p>
      </form>
      <div class="card-meta">
        <span class="meta-pill">⏱ 2 minutes</span>
        <span class="meta-pill">📄 5 documents inclus</span>
      </div>
    </aside>
  </div>
</section>

