<section class="hero hero-error">
  <div class="container">
    <div class="hero-card hero-card-error">
      <div class="error-badge">Oups, quelque chose a bloqué</div>
      <h1 class="error-title">Un problème est survenu</h1>
      <p class="error-text">
        {{message}}
      </p>
      <p class="error-note">
        Si le problème persiste, vous pouvez simplement réessayer dans quelques minutes ou nous contacter.
      </p>
      <a href="/" class="btn-cta btn-full">Revenir à la page d'accueil</a>
    </div>
  </div>
</section>

